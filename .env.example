# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded at startup by DotNetEnv (see Program.cs). Keys use the ASP.NET Core
# "__" convention to map onto nested config (ConnectionStrings:DefaultConnection,
# Jwt:Key, ...).

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=pos_db;Username=postgres;Password=your-postgres-password

# Used by docker compose: password for the bundled `db` postgres service and
# interpolated into the server container's connection string (Host=db).
POSTGRES_PASSWORD=your-postgres-password

# Must be at least 32 characters (HMAC-SHA256 signing key).
Jwt__Key=replace-with-a-long-random-secret-min-32-chars
Jwt__Issuer=POSApp
Jwt__Audience=POSApp

# Comma-separated list of browser origins allowed to call the API (CORS).
# Defaults to http://localhost:5173 when unset. In production add the deployed
# frontend origin, e.g. Cors__AllowedOrigins=https://your-app.pages.dev,http://localhost:5173
Cors__AllowedOrigins=http://localhost:5173
